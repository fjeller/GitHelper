{
  "appId": "com.githelper.app",
  "productName": "GitHelper",
  "directories": {
    "output": "out",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ]
  },
  "portable": {
    "unpackDirName": "GitHelper",
    "artifactName": "githelper-portable.exe"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "artifactName": "githelper-setup.exe"
  }
}
